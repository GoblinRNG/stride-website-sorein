<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#080b12">
  <title>
    {%- if request.page_type == 'index' -%}
      {{ page_title }} — {{ shop.name }}
    {%- elsif page_title contains shop.name -%}
      {{ page_title }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,900;1,400&display=swap" rel="stylesheet">
  {{ 'sorein-theme.css' | asset_url | stylesheet_tag }}
  {{ 'sorein-3d.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <script>
    window.Sorein = window.Sorein || {};
    window.Sorein.routes = {
      root_url: '{{ routes.root_url }}',
      cart_url: '{{ routes.cart_url }}',
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      search_url: '{{ routes.search_url }}'
    };
    window.Sorein.shop = {
      currency: '{{ cart.currency.iso_code }}',
      locale: '{{ request.locale.iso_code }}'
    };
    window.Sorein.cartState = {
      item_count: {{ cart.item_count }},
      total_price: {{ cart.total_price }}
    };
  </script>
</head>
<body class="sorein-body template-{{ request.page_type }}">

  {%- render 'sorein-icons-sprite' -%}

  <a class="sorein-skip-link" href="#sorein-main">Skip to content</a>

  {%- section 'sorein-announcement-bar' -%}
  {%- section 'sorein-header' -%}
  {%- render 'sorein-cart-drawer' -%}

  <main id="sorein-main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'sorein-footer' -%}

  <div id="sorein-toast" role="status" aria-live="polite" aria-atomic="true"></div>

  {{ 'sorein-theme.js' | asset_url | script_tag }}
  {{ 'sorein-energy-grid.js' | asset_url | script_tag }}
  {{ 'sorein-filter.js' | asset_url | script_tag }}
  {{ 'sorein-builder.js' | asset_url | script_tag }}

</body>
</html>
