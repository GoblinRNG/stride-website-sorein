<a href="{{ url | default: '#' }}"
   class="sorein-btn sorein-btn--{{ variant | default: 'primary' }}{% if size != blank %} sorein-btn--{{ size }}{% endif %}{% if class != blank %} {{ class }}{% endif %}"
   {% if aria_label != blank %}aria-label="{{ aria_label }}"{% endif %}
   {% if new_tab %}target="_blank" rel="noopener"{% endif %}>
  {{ label }}
  {%- if icon != blank -%}
    {% render 'sorein-icon', icon: icon, width: 18, height: 18 %}
  {%- endif -%}
</a>
