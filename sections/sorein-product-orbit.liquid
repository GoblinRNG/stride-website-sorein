{%- liquid
  assign section_mode = section.settings.product_page_mode
  if section_mode
    assign display_product = product
  endif
  assign orbit_collection = collections[section.settings.collection_handle]
-%}

{%- if section_mode -%}
  {%- comment -%} ── Product Detail Page Mode ── {%- endcomment -%}
  <div class="sorein-section sorein-pdp" data-section-id="{{ section.id }}" data-pdp-section>
    <div class="sorein-container">
      <div class="sorein-pdp__inner">

        {%- comment -%} Gallery {%- endcomment -%}
        <div class="sorein-pdp__gallery">
          <div class="sorein-pdp__main-img">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 900 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                width="900"
                height="900"
                loading="eager"
                id="sorein-pdp-main-img">
            {%- else -%}
              <img src="{{ 'product-1' | placeholder_svg_tag }}" alt="{{ product.title | escape }}" width="900" height="900">
            {%- endif -%}
          </div>
          {%- if product.images.size > 1 -%}
            <div class="sorein-pdp__thumbs">
              {%- for img in product.images limit: 6 -%}
                <button class="sorein-pdp__thumb{% if forloop.first %} is-active{% endif %}"
                  data-src="{{ img | image_url: width: 900 }}"
                  aria-label="{{ img.alt | default: product.title | escape }}">
                  <img src="{{ img | image_url: width: 144 }}" alt="{{ img.alt | default: product.title | escape }}" width="72" height="72" loading="lazy">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div><!-- /.sorein-pdp__gallery -->

        {%- comment -%} Info & Form {%- endcomment -%}
        <div class="sorein-pdp__form">
          <span class="sorein-eyebrow">{{ product.type | default: 'Power Station' }}</span>
          <h1 class="sorein-pdp__name">{{ product.title }}</h1>

          <div data-pdp-price-wrap>
            {%- render 'sorein-price', product: product -%}
          </div>

          {%- if product.description != blank -%}
            <div class="sorein-pdp__desc">{{ product.description | strip_html | truncate: 280 }}</div>
          {%- endif -%}

          {%- if product.has_only_default_variant == false -%}
            {%- for option in product.options_with_values -%}
              <div class="sorein-pdp__variants">
                <div class="sorein-pdp__variant-label">{{ option.name }}</div>
                <div class="sorein-pdp__variant-btns">
                  {%- for value in option.values -%}
                    {%- assign variant_for_value = product.variants | where: "option1", value | first -%}
                    {%- if variant_for_value == nil and option.position == 2 -%}
                      {%- assign variant_for_value = product.variants | where: "option2", value | first -%}
                    {%- endif -%}
                    <button class="sorein-pdp__variant-btn{% if forloop.first %} is-active{% endif %}"
                      data-variant-btn
                      data-variant-id="{{ variant_for_value.id }}"
                      data-variant-price="{{ variant_for_value.price }}"
                      {%- if variant_for_value.compare_at_price > variant_for_value.price -%}
                      data-variant-compare="{{ variant_for_value.compare_at_price }}"
                      {%- endif -%}
                      type="button">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            <input type="hidden" data-variant-btn data-variant-id="{{ product.first_available_variant.id }}"
              data-variant-price="{{ product.first_available_variant.price }}"
              {%- if product.first_available_variant.compare_at_price > product.first_available_variant.price -%}
              data-variant-compare="{{ product.first_available_variant.compare_at_price }}"
              {%- endif -%}
              class="is-active">
          {%- endif -%}

          <button class="sorein-pdp__add-btn" data-pdp-add-btn type="button" aria-label="{{ 'products.product.add_to_cart' | t }}">
            {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
          </button>

          <p class="sorein-pdp__klarna">
            {%- assign monthly_price = product.price | divided_by: 3600 -%}
            Or from {{ monthly_price | money }} / month with <strong>Klarna</strong>
          </p>

          <div class="sorein-pdp__guarantees">
            <span class="sorein-pdp__guarantee">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              5 Year Warranty
            </span>
            <span class="sorein-pdp__guarantee">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Free Delivery
            </span>
            <span class="sorein-pdp__guarantee">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.8"/><polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              Secure Checkout
            </span>
          </div>
        </div><!-- /.sorein-pdp__form -->

      </div><!-- /.sorein-pdp__inner -->
    </div><!-- /.sorein-container -->
  </div>

{%- else -%}
  {%- comment -%} ── Orbit / Collection Mode ── {%- endcomment -%}
  <div class="sorein-section sorein-orbit" data-section-id="{{ section.id }}" data-section-type="sorein-product-orbit">
    <div class="sorein-orbit__header sorein-container">
      <div>
        {%- if section.settings.heading != blank -%}
          <h2 class="sorein-orbit__title sorein-reveal">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="sorein-orbit__subtitle sorein-reveal sorein-reveal--delay-1">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
      <div class="sorein-orbit__nav">
        <button class="sorein-orbit__nav-btn" data-orbit-prev aria-label="Previous products">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="sorein-orbit__nav-btn" data-orbit-next aria-label="Next products">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <div class="sorein-orbit__track-wrap">
      <div class="sorein-orbit__track" role="list">
        {%- if orbit_collection != blank -%}
          {%- for p in orbit_collection.products -%}
            {%- render 'sorein-product-card', product: p, show_compare: section.settings.show_compare_price -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Fallback seed cards {%- endcomment -%}
          {%- assign fallback_names = 'A2 Lite 2.2kWh||A3 Lite 3.2kWh||A4 Lite 4.2kWh||A4 Backup 5.4kWh||A6 Ultra 6.4kWh||P1200 1.1kWh||P2400 2.1kWh||P3000 2.1kWh' | split: '||' -%}
          {%- assign fallback_prices = '16,995 kr||29,995 kr||29,995 kr||37,995 kr||49,995 kr||9,499 kr||16,490 kr||19,990 kr' | split: '||' -%}
          {%- assign fallback_caps = '2.2kWh||3.2kWh||4.2kWh||5.4kWh||6.4kWh||1.2kWh||2.4kWh||3.0kWh' | split: '||' -%}
          {%- assign fallback_outputs = '2200W||3000W||3000W||3000W||6000W||1200W||2400W||3000W' | split: '||' -%}
          {%- for i in (0..7) -%}
            <div class="sorein-product-card" role="listitem">
              <div class="sorein-product-card__img-wrap">
                {{ 'product-1' | placeholder_svg_tag: 'sorein-product-card__img' }}
              </div>
              <div class="sorein-product-card__body">
                <div class="sorein-product-card__specs">
                  <span class="sorein-product-card__spec">{{ fallback_caps[i] }}</span>
                  <span class="sorein-product-card__spec">{{ fallback_outputs[i] }}</span>
                </div>
                <h3 class="sorein-product-card__name">Sorein {{ fallback_names[i] }}</h3>
                <div class="sorein-product-card__footer">
                  <div class="sorein-price">
                    <span class="sorein-price__current">{{ fallback_prices[i] }}</span>
                  </div>
                  <a href="/collections/power-stations" class="sorein-product-card__cta">View</a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Sorein Product Orbit",
  "settings": [
    { "type": "checkbox", "id": "product_page_mode", "label": "Product page mode", "default": false },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Sorein System Range" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "collection", "id": "collection_handle", "label": "Collection to display" },
    { "type": "checkbox", "id": "show_compare_price", "label": "Show compare-at price", "default": true }
  ],
  "presets": [
    { "name": "Sorein Product Orbit" }
  ]
}
{% endschema %}
