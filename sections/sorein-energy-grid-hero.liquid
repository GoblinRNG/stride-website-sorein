<section class="sorein-hero" data-section-id="{{ section.id }}">

  <!-- Background layer -->
  <div class="sorein-hero__bg">
    <div class="sorein-hero__bg-gradient"></div>

    <!-- Energy grid CSS lines -->
    <div class="sorein-energy-grid-bg" aria-hidden="true">
      <div class="sorein-grid-lines"></div>
    </div>

    <!-- Spline scene (optional, lazy-loaded) -->
    {%- if settings.spline_hero_url != blank -%}
      <div class="sorein-hero__spline sorein-spline-wrap" data-spline-url="{{ settings.spline_hero_url }}">
        <div class="sorein-spline-loader" aria-hidden="true">
          <div class="sorein-spline-loader__dot"></div>
          <div class="sorein-spline-loader__dot"></div>
          <div class="sorein-spline-loader__dot"></div>
        </div>
      </div>
    {%- elsif settings.hero_fallback_image != blank -%}
      <div class="sorein-hero__spline-fallback">
        <img class="sorein-hero__fallback-img"
             src="{{ settings.hero_fallback_image | image_url: width: 1600 }}"
             alt=""
             loading="eager"
             width="1600" height="900">
      </div>
    {%- endif -%}
  </div>

  <!-- Content -->
  <div class="sorein-container">
    <div class="sorein-hero__content" data-animate="fade-up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="sorein-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="sorein-hero__title">
        {%- if section.settings.title_highlight != blank -%}
          {{ section.settings.heading | split: section.settings.title_highlight | first -}}
          <span class="sorein-gradient-text">{{ section.settings.title_highlight }}</span>
          {{- section.settings.heading | split: section.settings.title_highlight | last }}
        {%- else -%}
          {{ section.settings.heading }}
        {%- endif -%}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="sorein-hero__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="sorein-hero__cta">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url | default: routes.all_products_collection_url }}"
             class="sorein-btn sorein-btn--primary sorein-btn--lg">
            {{ section.settings.cta1_label }}
            <svg class="sorein-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url | default: '#sorein-builder' }}"
             class="sorein-btn sorein-btn--ghost sorein-btn--lg">
            {{ section.settings.cta2_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="sorein-hero__stats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="sorein-hero__stat" {{ block.shopify_attributes }}>
                <span class="sorein-hero__stat-value">{{ block.settings.value }}</span>
                <span class="sorein-hero__stat-label">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- Floating labels (decorative, hidden on mobile) -->
  <div class="sorein-hero__floating-labels" aria-hidden="true">
    <div class="sorein-hero__label sorein-hero__label--teal" style="top:20%;right:15%">LiFePO4</div>
    <div class="sorein-hero__label sorein-hero__label--solar" style="top:38%;right:5%">Solar Ready</div>
    <div class="sorein-hero__label" style="top:55%;right:18%">Modular</div>
    <div class="sorein-hero__label sorein-hero__label--battery" style="top:68%;right:8%">2 400 W Output</div>
    <div class="sorein-hero__label" style="top:78%;right:22%">Silent Power</div>
  </div>

</section>

{% schema %}
{
  "name": "Energy Grid Hero",
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "48 kg" },
        { "type": "text", "id": "label", "label": "Label", "default": "Total weight" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Premium Modular Power" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "Power Rebuilt for a New World." },
    { "type": "text", "id": "title_highlight", "label": "Highlighted word in headline", "default": "New World", "info": "This exact text in the headline will be gradient-highlighted." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium modular power stations and solar systems for home backup, off-grid living, travel, and emergency independence." },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA label", "default": "Shop Power Stations" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA label", "default": "Build Your System" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA URL" }
  ],
  "presets": [
    {
      "name": "Energy Grid Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "48 kg", "label": "System weight" } },
        { "type": "stat", "settings": { "value": "2 400 W", "label": "AC output" } },
        { "type": "stat", "settings": { "value": "30 days", "label": "Return policy" } }
      ]
    }
  ]
}
{% endschema %}
