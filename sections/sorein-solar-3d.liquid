<section class="sorein-solar sorein-reveal" data-section-id="{{ section.id }}">
  <div class="sorein-container">
    <div class="sorein-solar__layout">

      <!-- Solar visualization -->
      <div class="sorein-solar__vis" aria-hidden="true">
        <div class="sorein-solar__panel-group">
          <div class="sorein-solar__panel sorein-solar__panel--1"></div>
          <div class="sorein-solar__panel sorein-solar__panel--2"></div>
          <div class="sorein-solar__panel sorein-solar__panel--3"></div>
          <div class="sorein-solar__panel sorein-solar__panel--4"></div>
        </div>
        <div class="sorein-solar__flow-line" aria-hidden="true"></div>
        <div class="sorein-solar__charge-bar">
          <div class="sorein-solar__charge-fill"></div>
        </div>
        <div class="sorein-solar__charge-label">Charging…</div>
      </div>

      <!-- Content -->
      <div class="sorein-solar__content">
        <p class="sorein-section-eyebrow">{{ section.settings.eyebrow | default: 'Solar Integration' }}</p>
        <h2 class="sorein-section-title">{{ section.settings.title | default: 'Charge From the Sun' }}</h2>
        <p class="sorein-solar__desc">{{ section.settings.description | default: 'Connect solar panels directly to any SOREIN unit. No extra charge controller needed — plug in and power on.' }}</p>

        <div class="sorein-solar__specs">
          {%- for block in section.blocks -%}
            {%- if block.type == 'spec' -%}
              <div class="sorein-solar__spec-item" {{ block.shopify_attributes }}>
                <span class="sorein-solar__spec-value">{{ block.settings.value }}</span>
                <span class="sorein-solar__spec-label">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
             class="sorein-btn sorein-btn--primary">
            {{ section.settings.cta_label }}
            {% render 'sorein-icon', icon: 'arrow-right', width: 18, height: 18 %}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Solar 3D",
  "blocks": [
    {
      "type": "spec",
      "name": "Solar Spec",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "800W" },
        { "type": "text", "id": "label", "label": "Label", "default": "Max solar input" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Solar Integration" },
    { "type": "text", "id": "title", "label": "Title", "default": "Charge From the Sun" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Connect solar panels directly to any SOREIN unit. No extra charge controller needed — plug in and power on." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Solar Panels" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [
    {
      "name": "Solar 3D",
      "blocks": [
        { "type": "spec", "settings": { "value": "800W", "label": "Max solar input" } },
        { "type": "spec", "settings": { "value": "MPPT", "label": "Charge controller" } },
        { "type": "spec", "settings": { "value": "12–60V", "label": "Input range" } }
      ]
    }
  ]
}
{% endschema %}
