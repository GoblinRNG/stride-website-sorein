<footer class="sorein-footer" data-section-id="{{ section.id }}" role="contentinfo">
  <div class="sorein-container">

    <div class="sorein-footer__grid">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="sorein-footer__brand-col">
        <a href="{{ routes.root_url }}" class="sorein-nav__logo" aria-label="{{ shop.name }} home" style="text-decoration:none;">
          <div class="sorein-nav__logo-mark" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2L15 5.5V12.5L9 16L3 12.5V5.5L9 2Z" fill="white" opacity="0.9"/>
              <path d="M9 2L9 16" stroke="#00c9a7" stroke-width="1.5"/>
            </svg>
          </div>
          <span class="sorein-nav__logo-text">{{ shop.name | default: 'SOREIN' }}</span>
        </a>
        <p class="sorein-footer__brand-desc">
          {{ section.settings.brand_description | default: 'Modular energy systems designed for off-grid living, travel, and reliable home backup. Engineered for performance. Designed for independence.' | escape }}
        </p>
        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" style="color:rgba(255,255,255,0.4);transition:color 200ms;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.4)'" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" style="color:rgba(255,255,255,0.4);transition:color 200ms;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.4)'" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Link columns {%- endcomment -%}
      {%- assign col_titles = 'Products||Support||Company||Trust & Legal' | split: '||' -%}
      {%- assign col_links  = '/collections/power-stations,/collections/solar-panels,/pages/build-your-system,/collections/accessories||/pages/support,/pages/faq,/pages/warranty,/pages/contact||/pages/about,/blogs/news,/pages/technology,/pages/dealers||/pages/privacy-policy,/pages/terms-of-service,/pages/returns,/pages/compliance' | split: '||' -%}
      {%- assign col_labels = 'Power Stations,Solar Panels,Build Your System,Accessories||Support Center,FAQ,Warranty,Contact Us||About Sorein,News & Updates,Technology,Find a Dealer||Privacy Policy,Terms of Service,Returns Policy,Compliance & Safety' | split: '||' -%}

      {%- for i in (0..3) -%}
        <div>
          <h3 class="sorein-footer__col-title">{{ col_titles[i] }}</h3>
          {%- assign links = col_links[i] | split: ',' -%}
          {%- assign labels = col_labels[i] | split: ',' -%}
          <ul class="sorein-footer__links" role="list">
            {%- for j in (0..3) -%}
              <li class="sorein-footer__link-item" role="listitem">
                <a href="{{ links[j] }}" class="sorein-footer__link">{{ labels[j] }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}

    </div><!-- /.sorein-footer__grid -->

    <div class="sorein-footer__bottom">
      <p class="sorein-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Sorein' }}. All rights reserved.
      </p>

      <div class="sorein-footer__payment-icons" aria-label="Accepted payment methods">
        {%- assign payment_types = 'Klarna||Visa||Mastercard||Apple Pay||Google Pay||PayPal||Shop Pay' | split: '||' -%}
        {%- for pay in payment_types -%}
          <span class="sorein-footer__payment-icon">{{ pay }}</span>
        {%- endfor -%}
      </div>
    </div>

  </div><!-- /.sorein-container -->
</footer>

{% schema %}
{
  "name": "Sorein Footer",
  "settings": [
    { "type": "textarea", "id": "brand_description", "label": "Brand description" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" }
  ],
  "presets": [
    { "name": "Sorein Footer" }
  ]
}
{% endschema %}
