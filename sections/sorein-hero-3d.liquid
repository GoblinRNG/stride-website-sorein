<div class="sorein-section sorein-hero" data-section-id="{{ section.id }}" data-section-type="sorein-hero-3d">
  <div class="sorein-hero__bg-grid"></div>
  <div class="sorein-hero__bg-radial"></div>

  <div class="sorein-hero__inner">
    <div class="sorein-hero__content">
      <span class="sorein-eyebrow sorein-eyebrow--light sorein-reveal">Scandinavian Engineering</span>

      <h1 class="sorein-hero__headline sorein-reveal sorein-reveal--delay-1">
        {%- assign headline_parts = section.settings.headline | newline_to_br | split: '<br />' -%}
        {%- for part in headline_parts -%}
          {%- if part == section.settings.headline_accent -%}
            <span>{{ part }}</span>
          {%- else -%}
            {{ part -}}
            {%- unless forloop.last %}<br>{% endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </h1>

      <p class="sorein-hero__sub sorein-reveal sorein-reveal--delay-2">
        {{ section.settings.subheadline | escape }}
      </p>

      <div class="sorein-hero__ctas sorein-reveal sorein-reveal--delay-3">
        {%- if section.settings.cta_primary_text != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="sorein-btn sorein-btn--teal sorein-btn--lg">
            {{ section.settings.cta_primary_text | escape }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_text != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="sorein-btn sorein-btn--ghost-light sorein-btn--lg">
            {{ section.settings.cta_secondary_text | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="sorein-hero__trust sorein-reveal">
        {%- assign trust_items = section.settings.trust_1 | append: '||' | append: section.settings.trust_2 | append: '||' | append: section.settings.trust_3 | append: '||' | append: section.settings.trust_4 | split: '||' -%}
        {%- assign trust_icons = 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z||M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z||M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4||M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' | split: '||' -%}
        {%- for item in trust_items -%}
          {%- if item != blank -%}
            <div class="sorein-hero__trust-item">
              <svg class="sorein-hero__trust-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="{{ trust_icons[forloop.index0] }}" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ item | escape }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div><!-- /.sorein-hero__content -->

    <div class="sorein-hero__visual" aria-hidden="true">
      <div class="sorein-hero__canvas-wrap">
        <canvas id="sorein-hero-canvas"></canvas>

        <!-- CSS 3D fallback (always rendered, hidden by JS if Three.js loads) -->
        <div class="sorein-stack-3d" role="presentation">
          <div class="sorein-energy-rings">
            <div class="sorein-energy-ring"></div>
            <div class="sorein-energy-ring"></div>
            <div class="sorein-energy-ring"></div>
          </div>
          <div class="sorein-solar-beams">
            <div class="sorein-solar-beam"></div>
            <div class="sorein-solar-beam"></div>
            <div class="sorein-solar-beam"></div>
          </div>
          <div class="sorein-stack-3d__module sorein-stack-3d__module--inverter">
            <div class="sorein-stack-3d__module-label">Inverter</div>
            <div class="sorein-stack-3d__module-indicator"></div>
          </div>
          <div class="sorein-stack-3d__module sorein-stack-3d__module--battery">
            <div class="sorein-stack-3d__module-label">EB210 Battery Module</div>
            <div class="sorein-stack-3d__module-indicator"></div>
          </div>
          <div class="sorein-stack-3d__module sorein-stack-3d__module--base">
            <div class="sorein-stack-3d__module-label">A6 Base Station</div>
            <div class="sorein-stack-3d__module-indicator"></div>
          </div>
        </div>
      </div>
    </div><!-- /.sorein-hero__visual -->
  </div><!-- /.sorein-hero__inner -->
</div>

{% schema %}
{
  "name": "Sorein Hero 3D",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline", "default": "Power Anything,\nAnywhere." },
    { "type": "text", "id": "headline_accent", "label": "Accent word (gradient)", "default": "Anywhere." },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "Modular power systems built for Nordic conditions, off-grid living, and reliable home backup." },
    { "type": "text", "id": "cta_primary_text", "label": "Primary CTA text", "default": "Build Your System" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta_secondary_text", "label": "Secondary CTA text", "default": "Shop Power Stations" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA link" },
    { "type": "text", "id": "trust_1", "label": "Trust item 1", "default": "Klarna Available" },
    { "type": "text", "id": "trust_2", "label": "Trust item 2", "default": "Secure Payments" },
    { "type": "text", "id": "trust_3", "label": "Trust item 3", "default": "Free & Fast Delivery" },
    { "type": "text", "id": "trust_4", "label": "Trust item 4", "default": "5 Year Warranty" }
  ],
  "presets": [
    { "name": "Sorein Hero 3D" }
  ]
}
{% endschema %}
