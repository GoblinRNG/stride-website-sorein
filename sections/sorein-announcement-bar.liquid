{%- if section.settings.text != blank -%}
  <div class="sorein-announcement" role="banner" aria-label="Announcement">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text | escape }}</a>
    {%- else -%}
      <span>{{ section.settings.text | escape }}</span>
    {%- endif -%}
    {%- if section.settings.show_countdown and section.settings.countdown_end != blank -%}
      <span class="sorein-announcement__countdown" data-end="{{ section.settings.countdown_end | escape }}" aria-label="Countdown timer"></span>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Sorein Announcement Bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Announcement text", "default": "Save 5,000 SEK on Orders Over 25,000 SEK — Free Delivery Included" },
    { "type": "url", "id": "link", "label": "Link (optional)" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown timer", "default": false },
    { "type": "text", "id": "countdown_end", "label": "Countdown end date (ISO 8601)", "info": "e.g. 2025-01-31T23:59:59. Only show if you have a real end date." }
  ],
  "presets": [
    { "name": "Sorein Announcement Bar" }
  ]
}
{% endschema %}
