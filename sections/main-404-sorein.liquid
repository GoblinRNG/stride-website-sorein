<section class="sorein-404" data-section-id="{{ section.id }}">
  <div class="sorein-container">
    <div class="sorein-404__content">
      <div class="sorein-404__code" aria-hidden="true">404</div>
      <h1 class="sorein-404__title">{{ section.settings.title | default: 'Page not found' }}</h1>
      <p class="sorein-404__desc">{{ section.settings.description | default: "The page you're looking for has moved or doesn't exist." }}</p>
      <div class="sorein-404__actions">
        <a href="{{ routes.root_url }}" class="sorein-btn sorein-btn--primary sorein-btn--lg">
          {% render 'sorein-icon', icon: 'home', width: 18, height: 18 %}
          Back to Home
        </a>
        <a href="{{ routes.all_products_collection_url }}" class="sorein-btn sorein-btn--ghost sorein-btn--lg">
          Browse Products
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .sorein-404 {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 80px 0;
    background: var(--s-bg, #080b12);
    text-align: center;
  }
  .sorein-404__content {
    max-width: 480px;
    margin: 0 auto;
  }
  .sorein-404__code {
    font-size: 7rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, var(--s-teal, #00d4aa), var(--s-battery, #4db8ff));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }
  .sorein-404__title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--s-text, #e8edf5);
    margin: 0 0 12px;
  }
  .sorein-404__desc {
    color: var(--s-silver, #94a3b8);
    margin: 0 0 32px;
    line-height: 1.6;
  }
  .sorein-404__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

{% schema %}
{
  "name": "404 Page",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Page not found" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "The page you're looking for has moved or doesn't exist." }
  ],
  "presets": [
    { "name": "404 Page" }
  ]
}
{% endschema %}
